{
  "manifest_version": 3,
  "name": "commentree",
  "version": "1.0",
  "description": "Tree-shaped comment previews for Hacker News and Reddit",
  "content_scripts": [
    {
      "matches": [
        "*://news.ycombinator.com/item*",
        "*://old.reddit.com/r/*/comments/*",
        "*://www.reddit.com/r/*/comments/*"
      ],
      "css": ["style.css"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
